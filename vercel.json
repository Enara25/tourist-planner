{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/index.js" },
    { "src": "/place", "dest": "/public/pages/place.html" },
    { "src": "/planner", "dest": "/public/pages/planner.html" },
    { "src": "/login", "dest": "/public/pages/login.html" },
    { "src": "/register", "dest": "/public/pages/register.html" },
    { "src": "/admin", "dest": "/public/pages/admin.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
